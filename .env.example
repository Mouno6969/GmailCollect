# Telegram Bot Configuration
# IMPORTANT: Replace with your NEW token from @BotFather (revoke the old one!)
BOT_TOKEN=YOUR_NEW_BOT_TOKEN_HERE

# Security: ONLY allow commands from this Chat ID (get it from @userinfobot)
ALLOWED_CHAT_ID=YOUR_CHAT_ID_HERE

# GYB Configuration
GYB_PATH=/opt/gyb/gyb
BACKUP_DIR=/home/ubuntu/gmail_backups
